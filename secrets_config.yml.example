# secrets_config.yml.example — copy to secrets_config.yml and fill in your values.
# secrets_config.yml is listed in .gitignore and will never be committed.

cdse:
  username: your_cdse_email@example.com
  password: your_cdse_password

earthdata:
  username: your_earthdata_username
  password: your_earthdata_password

paths:
  download:    /path/to/s2_download/
  acolite_dir: /path/to/acolite/
  acolite_out: /path/to/acolite_output/
  mask_config: /path/to/mask_config.yml
